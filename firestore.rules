rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hilfsfunktion: Prüft, ob der Nutzer eingeloggt ist
    function isSignedIn() {
      return request.auth != null;
    }

    // Hilfsfunktion: Prüft, ob dem Nutzer das Dokument gehört
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- REGELN ---

    // USERS:
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      
      allow update: if isOwner(userId);
      
      // Löschen darf nur der Besitzer selbst
      allow delete: if isSignedIn() && isOwner(userId);
    }

    // PETS:
    match /pets/{petId} {
      allow read: if isSignedIn();
      // Erstellen erlaubt, wenn man sich selbst als Besitzer einträgt
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      // Update/Löschen nur erlaubt, wenn man der Besitzer IST
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // MARKET:
    match /market/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      // Only the seller can delete their own listing via client SDK.
      // Purchases are handled server-side by the buyMarketItem Cloud Function (admin SDK bypasses this rule).
      allow delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    // FEEDBACK:
    match /feedback/{feedbackId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Only admins may update the processing status field
      allow update: if isSignedIn()
        && request.auth.token.email == '2fast2hunter@gmail.com'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // GLOBAL CHAT:
    match /globalChat/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 200;
      allow update, delete: if false;
    }

    // GUILDS:
    match /guilds/{guildId} {
      allow read: if isSignedIn();
      // Only authenticated users can create guilds
      allow create: if isSignedIn() && request.resource.data.leaderId == request.auth.uid;
      // Members can update (join/leave handled via transactions server-side)
      allow update: if isSignedIn();
      // Only leader can delete
      allow delete: if isSignedIn() && resource.data.leaderId == request.auth.uid;

      // Guild chat messages subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if false; // Messages are permanent
      }
    }
  }
}