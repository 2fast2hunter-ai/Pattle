rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hilfsfunktion: Prüft, ob der Nutzer eingeloggt ist
    function isSignedIn() {
      return request.auth != null;
    }

    // Hilfsfunktion: Prüft, ob dem Nutzer das Dokument gehört
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- REGELN ---

    // USERS:
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      
      allow update: if isOwner(userId);
      
      // Löschen darf nur der Besitzer selbst
      allow delete: if isSignedIn() && isOwner(userId);
    }

    // PETS:
    match /pets/{petId} {
      allow read: if isSignedIn();
      // Erstellen erlaubt, wenn man sich selbst als Besitzer einträgt
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      // Update/Löschen nur erlaubt, wenn man der Besitzer IST
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // MARKET:
    match /market/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      // Only the seller can delete their own listing via client SDK.
      // Purchases are handled server-side by the buyMarketItem Cloud Function (admin SDK bypasses this rule).
      allow delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    // FEEDBACK:
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
    }
  }
}